APP_NAME=recruiter-brain-backend
APP_ENV=production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_KEY_REQUIRED=true
API_KEY=change-this-api-key

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/recruiter_brain
REDIS_URL=redis://valkey:6379/0

LLM_BASE_URL=http://llm:8080/v1
LLM_MODEL=qwen2.5-1.5b-instruct-q4_k_m
LLM_TIMEOUT_SECONDS=45
LLM_ENABLED=true
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512

MODEL_FILE=Qwen2.5-1.5B-Instruct-Q4_K_M.gguf
LLM_CTX_SIZE=3072
LLM_THREADS=8
LLM_BATCH=512
LLM_GPU_LAYERS=0

MAX_UPLOAD_BYTES=15000000
CACHE_TTL_SECONDS=900
MAX_BATCH_CANDIDATES=200
RANK_WEIGHT_LLM=0.70
RANK_WEIGHT_HARD_SKILL=0.20
RANK_WEIGHT_EXPERIENCE=0.10
OVERCLAIM_PENALTY=1.00
